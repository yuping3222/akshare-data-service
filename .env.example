# AKShare Data Service - Environment Variables Template
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ============================================================
# Cache Configuration
# ============================================================

# Directory for cached parquet files
AKSHARE_DATA_CACHE_DIR=./cache

# Maximum number of items in memory cache (default: 5000)
AKSHARE_DATA_CACHE_MAX_ITEMS=5000

# Default TTL for in-memory cache in seconds (default: 3600 = 1 hour)
AKSHARE_DATA_CACHE_TTL_SECONDS=3600

# Parquet compression algorithm: snappy, gzip, zstd, lz4, brotli
AKSHARE_DATA_CACHE_COMPRESSION=snappy

# Row group size for parquet files
AKSHARE_DATA_CACHE_ROW_GROUP_SIZE=100000

# DuckDB thread pool size
AKSHARE_DATA_CACHE_DUCKDB_THREADS=4

# DuckDB memory limit (e.g., 2GB, 4GB)
AKSHARE_DATA_CACHE_DUCKDB_MEMORY_LIMIT=4GB

# Log level: DEBUG, INFO, WARNING, ERROR
AKSHARE_DATA_CACHE_LOG_LEVEL=INFO

# Cache retention period in hours (0 = no expiration)
AKSHARE_DATA_CACHE_RETENTION_HOURS=0

# Strict schema validation: true/false
AKSHARE_DATA_CACHE_STRICT_SCHEMA=false

# ============================================================
# Config Directory
# ============================================================

# Override default config directory location
# AKSHARE_DATA_CONFIG_DIR=./config

# ============================================================
# API Tokens
# ============================================================

# Lixinger OpenAPI token (required for lixinger source)
# Migrated from token.cfg — do NOT commit .env
LIXINGER_TOKEN=ffad9101-8689-4b5d-bd79-763c58522a95

# Tushare Pro token (optional, for tushare source)
TUSHARE_TOKEN=4b33969578cd316eb788f60605711745360834aded78ac672f2a0537

# ============================================================
# Optional: Source-specific settings
# ============================================================

# Tushare API rate limit (calls per minute)
# TUSHARE_RATE_LIMIT=200

# AKShare request timeout (seconds)
# AKSHARE_REQUEST_TIMEOUT=30

# AKShare max retries per request
# AKSHARE_MAX_RETRIES=3

# ============================================================
# Logging (optional, defaults shown)
# ============================================================

# Log level for the application
# AKSHARE_DATA_LOG_LEVEL=INFO

# Log file path
# AKSHARE_DATA_LOG_FILE=logs/akshare_data.log

# Override logs directory (default: ./logs)
# AKSHARE_DATA_LOGS_DIR=./logs

# Override reports directory (default: ./reports)
# AKSHARE_DATA_REPORTS_DIR=./reports
